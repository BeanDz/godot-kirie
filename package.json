{
  "name": "godot-kirie",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:packages": "pnpm -rF './packages/*' run build",
    "format:biome": "biome check --write .",
    "lint:biome": "biome check .",
    "release": "bumpp",
    "test:ios-ipc-serialization": "bash scripts/run_basic_ipc_ios.sh",
    "test:unit": "pnpm -rF './packages/*' run test:run",
    "typecheck": "pnpm -rF './packages/*' run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "bumpp": "^11.0.1",
    "execa": "9.6.1"
  }
}
