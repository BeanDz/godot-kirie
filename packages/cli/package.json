{
  "name": "@gd-kirie/cli",
  "version": "0.1.1",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/moeru-ai/godot-kirie.git",
    "directory": "packages/cli"
  },
  "bin": {
    "kirie": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "citty": "^0.2.2",
    "execa": "9.6.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "tsdown": "^0.22.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  }
}
